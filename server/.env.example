# Copy to .env and fill in values.
# For Render: set these in Dashboard → Your Web Service → Environment.
# Set NODE_ENV=production on Render if you want production behavior (optional; RENDER=true is also treated as production).

PORT=5000
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname?appName=App
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Local: http://localhost:5000/auth/google/callback
# Render: https://YOUR-SERVICE-NAME.onrender.com/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback
SESSION_SECRET=your-session-secret-min-32-chars

# Required in production. Local: http://localhost:5173
# Render: your frontend URL, e.g. https://your-frontend.onrender.com (no trailing slash)
# If missing in production, login redirects will fail (server will not start).
FRONTEND_URL=http://localhost:5173

# Optional: comma-separated emails that get the "principal" role
PRINCIPAL_EMAILS=
